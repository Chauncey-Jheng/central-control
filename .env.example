# Main app
HOST=0.0.0.0
PORT=3000

# Child apps
# 子程序统一经中控主端口下的 /apps/:appId/ 反向代理访问，因此只需绑定回环地址，
# 不再需要单独对外暴露每个子程序端口。
CHILD_HOST=127.0.0.1
CHILD_BASE_PORT=4000

# satellite 子程序（FY3F 卫星遥测分析 App，Python + FastAPI/uvicorn）
# SATELLITE_ROOT   卫星仓库根目录（uvicorn 的工作目录）
# SATELLITE_PYTHON 已安装 app/backend/requirements.txt 依赖的 Python 解释器
SATELLITE_ROOT=/Users/zhengchengxin/workplace/satellite
SATELLITE_PYTHON=python3
# 可选：Agent LLM 接入（不配则降级为本地模板回答）
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=
# LLM_MODEL=deepseek-chat
