# Main app
HOST=0.0.0.0
PORT=3000

# Child apps
# 子程序默认绑定 0.0.0.0，内网可以直接用 主机IP:子程序端口 访问；
# 公网侧只暴露中控主端口，子程序端口不对外网开放，公网访问始终经中控 /apps/:appId/ 统一路由。
CHILD_HOST=0.0.0.0
CHILD_BASE_PORT=4000
# 可选：页面展示本机子程序时用的内网 IP（0.0.0.0 不是能直接连的地址，展示时要换成真实 IP）。
# 不填则中控启动时自动探测本机第一个非回环 IPv4 地址；多网卡/探测结果不对时才需要手动指定。
# LAN_HOST=192.168.1.10

# satellite 子程序（FY3F 卫星遥测分析 App，Python + FastAPI/uvicorn）
# SATELLITE_ROOT   卫星仓库根目录（uvicorn 的工作目录）
# SATELLITE_PYTHON 已安装 app/backend/requirements.txt 依赖的 Python 解释器
SATELLITE_ROOT=/Users/zhengchengxin/workplace/satellite
SATELLITE_PYTHON=python3

# pcrl-mrg 子程序（脑CT报告生成推理系统，Python + FastAPI/uvicorn）
# PCRL_MRG_ROOT   PCRL-MRG 仓库根目录（uvicorn 工作目录是其下的 inference/ 子目录）
# PCRL_MRG_PYTHON 已安装依赖（含 torch/transformers/peft/bitsandbytes 等）且能访问 GPU 的解释器
PCRL_MRG_ROOT=/home/bjutcv/data/zcx/PCRL-MRG
PCRL_MRG_PYTHON=/home/bjutcv/anaconda3/envs/zcx_llama/bin/python
# 可选：Agent LLM 接入（不配则降级为本地模板回答）
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=
# LLM_MODEL=deepseek-chat
